# ── Gmail OAuth2 (Google Cloud Console → Desktop app credentials) ──
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
# Generated by `npm run auth`. Leave blank until then.
GMAIL_REFRESH_TOKEN=

# ── Notion ──
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=e452d104-c168-4da9-8e76-953fb9057e30

# ── Telegram notifications (optional — set BOTH to enable, or leave BOTH blank) ──
# Token from @BotFather. Chat ID: message your bot, then run `npm run telegram:chat-id`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional tuning (sensible defaults shown) ──
# Gmail search query for shipping mail. Covers Amazon + UPS/FedEx/USPS/India
# Post. Parentheses group the senders so `label:inbox` applies to all of them
# (Gmail binds OR loosely without them).
GMAIL_QUERY=(from:shipment-tracking@amazon.com OR from:auto-confirm@amazon.in OR from:ups.com OR from:fedex.com OR from:usps.com OR from:indiapost.gov.in) label:inbox
# Cron expression for the poll loop (default: every 30 minutes).
POLL_CRON=*/30 * * * *

# Daily digest: one Telegram summary of what's in transit. Requires Telegram.
# Leave unset to disable. Example below = 8:00am daily.
DIGEST_CRON=0 8 * * *

# Subscription detection: scan receipt/billing mail for recurring charges and
# alert via Telegram. Leave unset to disable. Tune the senders/keywords to your
# inbox. Runs on the same POLL_CRON loop as shipping.
SUBSCRIPTION_QUERY=(subject:receipt OR subject:invoice OR subject:subscription OR subject:"your payment" OR subject:renewed) label:inbox
# Loopback port used only during the one-time `npm run auth` flow.
OAUTH_REDIRECT_PORT=4567
# Fuse.js match threshold, 0 (exact) .. 1 (loose). Matches above this are rejected.
MATCH_THRESHOLD=0.4
# Where to persist the last-processed timestamp and the run log.
STATE_FILE=state.json
LOG_FILE=tracker.log
