# ── Gmail OAuth2 (Google Cloud Console → Desktop app credentials) ──
# One shared OAuth app authorizes every account. Each account is authorized
# separately and stores its own refresh token in accounts.json (gitignored).
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret

# Authorize an inbox:  npm run auth -- <label>   (e.g. npm run auth -- personal)
# List configured labels:  npm run accounts
# Path to the label → refresh-token file (gitignored; written by `npm run auth`).
ACCOUNTS_FILE=accounts.json

# Legacy single-account fallback. Leave blank — prefer accounts.json above.
# Only used if accounts.json is empty/absent; adopted as the account "default".
GMAIL_REFRESH_TOKEN=

# ── Notion ──
# The integration needs only "Read content" + "Update content" capabilities
# (no Insert/Delete, no user information). Connect it to the database via
# ••• → Connections. Startup verifies access and exits if it can't read the DB.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=e452d104-c168-4da9-8e76-953fb9057e30

# ── Telegram notifications (optional — set BOTH to enable, or leave BOTH blank) ──
# Token from @BotFather. Chat ID: message your bot, then run `npm run telegram:chat-id`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional tuning (sensible defaults shown) ──
# Gmail search query for shipping mail (same query for every account). Covers
# Amazon + UPS/FedEx/USPS/India Post. Parentheses group the senders so
# `label:inbox` applies to all of them (Gmail binds OR loosely without them).
GMAIL_QUERY=(from:shipment-tracking@amazon.com OR from:auto-confirm@amazon.in OR from:ups.com OR from:fedex.com OR from:usps.com OR from:indiapost.gov.in) label:inbox
# Cron expression for the poll loop (default: every 30 minutes).
POLL_CRON=*/30 * * * *

# Daily digest: one Telegram summary of what's in transit. Requires Telegram.
# Leave unset to disable. Example below = 8:00am daily.
DIGEST_CRON=0 8 * * *

# Subscription detection: scan receipt/billing mail for recurring charges and
# alert via Telegram. Same query for every account. Leave unset to disable.
SUBSCRIPTION_QUERY=(subject:receipt OR subject:invoice OR subject:subscription OR subject:"your payment" OR subject:renewed) label:inbox

# Forwarder (ForwardMe) package tracking: a standalone Notion DB for packages
# held at the forwarder (keyed by ForwardMe's package code), separate from the
# book DB. Leave FORWARDER_DATABASE_ID unset to disable. NOTE: the integration
# needs "Insert content" on this DB (it creates a row per package).
FORWARDER_DATABASE_ID=
FORWARDER_QUERY=from:automated@forwardme.com

# Digital game tracking: a standalone Notion DB for digital game purchases from
# Nintendo eShop (US + JP) and Amazon JP game codes. Wallet top-ups (Funds
# Added / prepaid) and NSO subscriptions are excluded. Needs "Insert content".
# Leave GAMES_DATABASE_ID unset to disable.
GAMES_DATABASE_ID=
GAMES_QUERY=(from:digital-no-reply@amazon.co.jp OR from:digitalorder-update@amazon.co.jp OR (from:accounts.nintendo.com (subject:ご利用明細 OR subject:予約確認 OR subject:receipt OR subject:purchase)))

# Cross-DB spend summary: rolls per-month USD spend across the spend-bearing DBs
# (books + games) into a Source × Month "Spend Summary" DB, so total spend is
# viewable in one currency. Needs "Insert content". Unset → disabled.
SPEND_SUMMARY_DATABASE_ID=

# Loopback port used only during the one-time `npm run auth` flow.
OAUTH_REDIRECT_PORT=4567
# Fuse.js match threshold, 0 (exact) .. 1 (loose). Matches above this are rejected.
MATCH_THRESHOLD=0.4
# Where to persist per-account watermarks + links and the run log.
STATE_FILE=state.json
LOG_FILE=tracker.log

# ── Runtime guardrails ──
# Preview mode: parse + match + log, but NO Notion writes, NO Telegram sends,
# NO LLM calls, and state is not persisted. Safe for tuning queries/threshold.
DRY_RUN=false
# Soft alarm: if one tick applies more Notion updates than this, warn + ping
# (likely a misconfigured query). Not a hard stop.
MAX_UPDATES_PER_TICK=25

# ── Optional LLM fallback (opt-in; fills gaps the regex/keywords leave) ──
# Used only for gaps: status the regex can't read, and category+tags for items
# the keyword lists can't type. DATA EGRESS: when enabled, the subject +
# (truncated) body of such mail is sent to Anthropic's API. Content leaves this
# host. Opt-in and disabled by default.
LLM_FALLBACK=false
# Required when LLM_FALLBACK is on. Without it, the fallback stays disabled.
ANTHROPIC_API_KEY=
# Cost lever: leave blank to use the default model, or set a smaller/cheaper
# model id to cut cost (classification is easy and works well on cheaper tiers).
LLM_MODEL=
# Hard cap on LLM calls per tick, summed across ALL accounts (bounds spend if a
# query floods inboxes with non-shipping mail).
MAX_LLM_CALLS_PER_TICK=10
